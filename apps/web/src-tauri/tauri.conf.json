{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tetra",
  "version": "0.1.0",
  "identifier": "app.tetra.desktop",
  "build": {
    "frontendDist": "../dist-desktop",
    "devUrl": "http://localhost:5299",
    "beforeDevCommand": "bun run dev:tauri",
    "beforeBuildCommand": "bun run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Tetra",
        "width": 1200,
        "height": 800,
        "minWidth": 760,
        "minHeight": 540,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
