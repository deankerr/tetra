{
  "name": "tetra",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.13",
      "@types/node": "24.12.4",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "ai": "6.0.177",
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "tailwindcss": "4.3.0",
      "tinybase": "8.3.0",
      "typescript": "6.0.3"
    }
  },
  "type": "module",
  "scripts": {
    "build:vercel": "rm -rf .vercel/output apps/web/.vercel/output && NITRO_PRESET=vercel bun run --filter @tetra/web build && mkdir -p .vercel && mv apps/web/.vercel/output .vercel/output",
    "check": "ultracite check --type-aware --type-check",
    "dev": "bun run --filter @tetra/web dev",
    "fix": "ultracite fix --type-aware --type-check",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "knip": "^6.12.2",
    "lefthook": "^2.1.6",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "catalog:",
    "ultracite": "7.6.4"
  },
  "packageManager": "bun@1.3.13"
}
