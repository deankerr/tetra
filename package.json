{
  "name": "tetra",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:vercel": "rm -rf .vercel/output apps/web/.vercel/output && NITRO_PRESET=vercel bun run --filter @tetra/web build && mkdir -p .vercel && mv apps/web/.vercel/output .vercel/output",
    "check": "oxlint --type-aware --type-check --fix . && oxfmt --write .",
    "dev": "bun run --filter @tetra/web dev",
    "repl": "bun run --cwd apps/repl repl.ts"
  },
  "devDependencies": {
    "oxfmt": "0.40.0",
    "oxlint": "1.50.0",
    "oxlint-tsgolint": "0.15.0",
    "ultracite": "^7.3.2"
  },
  "packageManager": "bun@1.3.10"
}
