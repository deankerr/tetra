{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreIssues": {
    "packages/ui/src/components/ai-elements/**": ["exports", "types"],
    "packages/ui/src/components/ui/**": ["exports", "types"]
  },
  "workspaces": {
    ".": {
      "entry": ["package.json"],
      "project": ["*.{js,cjs,mjs,ts,cts,mts}"]
    },
    "apps/cli": {
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "entry": ["src/router.tsx", "src/routes/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/worker": {
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "includeEntryExports": true,
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/core": {
      "includeEntryExports": true,
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/tinybase-schema": {
      "includeEntryExports": true,
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
